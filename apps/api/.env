DATABASE_URL="mysql://root:@localhost:3306/samha_crm"
NODE_ENV="development"
PORT=3000

# Auth — dev-only placeholder, replace with `openssl rand -base64 64` value
JWT_SECRET="dev-only-replace-me-with-openssl-rand-base64-64-output"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL_DAYS=30
PASSWORD_RESET_TTL_MIN=60
PASSWORD_RESET_URL_BASE="http://localhost:5173/reset-password"
SEED_DEFAULT_PASSWORD="ChangeMe123!"

# CORS allowlist
ALLOWED_ORIGINS="http://localhost:5173"

# AWS S3 Configuration for Document Management
AWS_S3_BUCKET="your-bucket-name"
AWS_S3_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
MAX_UPLOAD_SIZE=52428800
