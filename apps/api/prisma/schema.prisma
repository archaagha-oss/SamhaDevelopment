// ============================================================
// Prisma Schema — Real Estate CRM
// Provider : MySQL (Prisma 5)
// Last updated : 2026-04-18
// Covers Phases 1–5: core domain, multi-project, events/jobs,
//                    financial system, pricing engine
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// SECTION 1: ENUMERATIONS
// ============================================================

// ----- Unit -----

enum UnitStatus {
  NOT_RELEASED
  AVAILABLE
  ON_HOLD    // temporary soft hold during offer period (auto-expires)
  RESERVED
  BOOKED
  SOLD
  HANDED_OVER
  BLOCKED
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum CompletionStatus {
  OFF_PLAN
  UNDER_CONSTRUCTION
  READY
}

enum PropertyPurpose {
  SALE
  RENT
}

enum FurnishingStatus {
  UNFURNISHED
  SEMI_FURNISHED
  FURNISHED
}

enum UnitType {
  STUDIO
  ONE_BR
  TWO_BR
  THREE_BR
  FOUR_BR
  COMMERCIAL
}

enum ViewType {
  SEA
  GARDEN
  STREET
  BACK
  SIDE
  AMENITIES
}

enum UnitImageType {
  PHOTO
  FLOOR_PLAN
  FLOOR_MAP
}

// ----- User / Access -----

enum UserRole {
  ADMIN
  SALES_AGENT
  OPERATIONS
  FINANCE
  DEVELOPER
}

enum ProjectRole {
  PROJECT_ADMIN
  SALES
  FINANCE
  VIEWER
}

// ----- Lead -----

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  OFFER_SENT
  SITE_VISIT
  NEGOTIATING
  CLOSED_WON
  CLOSED_LOST
}

// ----- Reservation -----

enum ReservationStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  CONVERTED
}

// ----- Offer -----

enum OfferStatus {
  ACTIVE
  ACCEPTED
  REJECTED
  EXPIRED
  WITHDRAWN
}

// ----- Deal -----

enum DealStage {
  RESERVATION_PENDING
  RESERVATION_CONFIRMED
  SPA_PENDING
  SPA_SENT
  SPA_SIGNED
  OQOOD_PENDING
  OQOOD_REGISTERED
  INSTALLMENTS_ACTIVE
  HANDOVER_PENDING
  COMPLETED
  CANCELLED
}

// ----- Payment -----

enum PaymentStatus {
  PENDING
  PARTIAL
  OVERDUE
  PAID
  PDC_PENDING
  PDC_CLEARED
  PDC_BOUNCED
  CANCELLED
}

enum MilestoneType {
  BOOKING_DEPOSIT
  DLD_FEE
  ADMIN_FEE
  CONSTRUCTION_STAGE
  HANDOVER_PAYMENT
  CUSTOM
}

enum MilestoneTrigger {
  DAYS_FROM_RESERVATION  // dueDate = reservationDate + daysFromReservation
  FIXED_DATE             // dueDate = fixedDate (specific calendar date)
  ON_SPA_SIGNING         // dueDate auto-set when deal reaches SPA_SIGNED
  ON_OQOOD               // dueDate auto-set when deal reaches OQOOD_REGISTERED
  ON_HANDOVER            // dueDate auto-set when deal reaches HANDOVER_PENDING
  ON_CONSTRUCTION_PCT    // dueDate auto-set when project's construction reaches triggerConstructionPct
}

// ----- Commission -----

enum CommissionStatus {
  NOT_DUE
  PENDING_APPROVAL
  APPROVED
  PAID
  FORFEITED
  CANCELLED
}

// ----- Document -----

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  ARCHIVED
}

enum DocumentType {
  PASSPORT
  EMIRATES_ID
  VISA
  SALES_OFFER
  RESERVATION_FORM
  SPA
  OQOOD_CERTIFICATE
  PAYMENT_RECEIPT
  OTHER
}

enum DocumentSource {
  GENERATED
  SIGNED
  UPLOADED
}

// ----- Contact -----

enum ContactSource {
  MANUAL
  LEAD
  BROKER
  REFERRAL
  IMPORT
}

// ----- Background jobs -----

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ----- Late fee -----

enum LateFeeType {
  PERCENTAGE_PER_DAY
  FIXED_ONE_TIME
  PERCENTAGE_PER_MONTH
}

// ----- Pricing engine -----

enum PricingScope {
  PROJECT
  UNIT_TYPE
  FLOOR
  VIEW
  UNIT
}

enum PricingAdjustmentType {
  PERCENTAGE_INCREASE
  PERCENTAGE_DECREASE
  FIXED_INCREASE
  FIXED_DECREASE
}

// ----- Task -----

enum TaskType {
  CALL
  MEETING
  FOLLOW_UP
  DOCUMENT
  PAYMENT
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  COMPLETED
  OVERDUE
}

// ----- Notifications -----

enum NotificationType {
  PAYMENT_OVERDUE
  RESERVATION_EXPIRING
  COMMISSION_PENDING
  OQOOD_DEADLINE
  DEAL_STAGE_CHANGED
  NEW_LEAD_ASSIGNED
  GENERAL
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ----- Phase 1: domain expansions -----

enum Tenure {
  FREEHOLD
  LEASEHOLD
}

enum ReleaseStage {
  INTERNAL        // not yet visible to brokers or public
  BROKER_PREVIEW  // brokers can reserve on behalf of leads
  PUBLIC          // open for public sale
}

enum KYCStatus {
  PENDING
  IN_REVIEW
  APPROVED
  EXPIRED
  REJECTED
}

enum RiskRating {
  LOW
  MEDIUM
  HIGH
}

enum PartyRole {
  PRIMARY     // primary buyer (must be exactly one per deal)
  CO_BUYER    // joint owner
  GUARANTOR   // legally responsible but not on title
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
  CREDITED
}

enum InvoiceLineKind {
  UNIT_PRICE
  DLD_FEE
  ADMIN_FEE
  REGISTRATION_FEE
  VAT
  ADJUSTMENT
  OTHER
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  PROCESSED
  CANCELLED
}

enum EscrowEntryDirection {
  CREDIT  // money in (customer payment)
  DEBIT   // money out (developer drawdown / refund / fees)
}

enum EscrowEntryReason {
  CUSTOMER_PAYMENT
  DEVELOPER_DRAWDOWN
  REFUND
  BANK_FEE
  TRANSFER
  OPENING_BALANCE
  ADJUSTMENT
}

enum SnagSeverity {
  COSMETIC
  MINOR
  MAJOR
  CRITICAL
}

enum SnagStatus {
  RAISED
  ACKNOWLEDGED
  IN_PROGRESS
  FIXED
  REJECTED
  CLOSED
}

enum HandoverItemStatus {
  PENDING
  COMPLETED
  WAIVED
  NOT_APPLICABLE
}

enum TitleDeedStatus {
  PENDING
  IN_PROGRESS
  ISSUED
  TRANSFERRED
  CANCELLED
}

enum ConstructionStage {
  EXCAVATION
  FOUNDATION
  STRUCTURE
  ENCLOSURE
  MEP
  FINISHES
  HANDOVER_READY
  COMPLETED
}

enum CommissionSplitParty {
  COMPANY
  AGENT
  SUB_AGENT
  REFERRER
}

enum LeaseStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
  RENEWED
}

enum ResaleStatus {
  ACTIVE
  WITHDRAWN
  SOLD
  EXPIRED
}

enum FacilityWorkOrderStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ============================================================
// SECTION 2: ORGANIZATION & PROJECT
// ============================================================

model Organization {
  id       String    @id @default(cuid())
  name     String    @unique
  country  String    @default("UAE")
  currency String    @default("AED")
  timezone String    @default("Asia/Dubai")

  projects    Project[]
  appSettings AppSettings?
  contacts    Contact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Project {
  id             String        @id @default(cuid())
  name           String        @unique
  location       String
  description    String?       @db.Text
  totalUnits     Int
  totalFloors    Int?
  projectStatus  ProjectStatus @default(ACTIVE)
  handoverDate   DateTime
  launchDate     DateTime?
  startDate      DateTime?

  completionStatus CompletionStatus @default(OFF_PLAN)
  purpose          PropertyPurpose  @default(SALE)
  furnishing       FurnishingStatus @default(UNFURNISHED)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  units              Unit[]
  leads              Lead[]
  config             ProjectConfig?
  userAccess         UserProjectAccess[]
  lateFeeRules       LateFeeRule[]
  pricingRules       PricingRule[]
  images             ProjectImage[]
  stageDocumentRules StageDocumentRule[]

  // Phase 1 expansions
  phases                Phase[]
  unitTypePlans         UnitTypePlan[]
  constructionMilestones ConstructionMilestone[]
  escrowAccounts        EscrowAccount[]
  trusteeAccounts       TrusteeAccount[]
  tieredCommissionRules TieredCommissionRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([organizationId])
}

model ProjectImage {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  url       String
  caption   String?
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())

  @@index([projectId])
}

model ProjectConfig {
  id              String  @id @default(cuid())
  projectId       String  @unique
  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  dldPercent       Float   @default(4)
  adminFee         Float   @default(5000)
  reservationDays  Int     @default(7)
  oqoodDays        Int     @default(90)

  vatPercent       Float   @default(0)
  agencyFeePercent Float   @default(2)
  unitsPerFloor    Int     @default(8)
  totalFloors      Int?

  defaultUnitType String? @default("STUDIO")
  defaultArea      Float?  @default(750)
  defaultView      String? @default("GARDEN")
  defaultPrice     Float?

  // Phase 1 expansions
  taxRegistrationNumber String? // TRN — printed on tax invoices
  fiscalYearStartMonth  Int     @default(1) // 1=January
  defaultDlpMonths      Int     @default(12) // Defect Liability Period after handover
  baseCurrency          String  @default("AED")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserProjectAccess {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      ProjectRole @default(SALES)

  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
}

// ============================================================
// SECTION 3: USER
// ============================================================

model User {
  id       String   @id @default(cuid())
  clerkId  String   @unique
  email    String   @unique
  name     String
  role     UserRole

  phone      String?
  department String?

  assignedLeads  Lead[]             @relation("AssignedLeads")
  assignedUnits  Unit[]             @relation("AssignedUnits")
  notifications  Notification[]
  projectAccess  UserProjectAccess[]
  tasks          Task[]             @relation("AssignedTasks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
}

// ============================================================
// SECTION 4: UNIT
// ============================================================

model Unit {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  unitNumber String
  floor      Int
  type       UnitType
  area       Float     // sq metres
  basePrice  Float     // original list price — immutable after creation
  price      Float     // current asking price (AED)
  view       ViewType

  // Physical layer
  bathrooms      Int?
  parkingSpaces  Int?
  internalArea   Float?   // suite sq metres (CSV: Suite SQ.M)
  externalArea   Float?   // balcony sq metres (CSV: Balcony SQ.M)

  status        UnitStatus         @default(NOT_RELEASED)
  statusHistory UnitStatusHistory[]

  // Operational layer
  blockReason    String?
  blockExpiresAt DateTime?
  holdExpiresAt  DateTime?
  internalNotes  String?  @db.Text
  tags           Json?    // string array e.g. ["corner", "premium"]
  paymentPlan    String?  // e.g. "60/40", "50/50", "40/60"

  // Phase 1: assignments (operational agent tracking — not buyer tracking)
  assignedAgent   User?   @relation("AssignedUnits", fields: [assignedAgentId], references: [id])
  assignedAgentId String?

  // ----- Domain extensions (Phase 1) -----
  tenure              Tenure?           // FREEHOLD | LEASEHOLD
  makaniNumber        String?           // Dubai address code
  dldUnitId           String?           // DLD-issued unit identifier
  plotNumber          String?
  titleDeedNumber     String?           // populated post-handover
  orientation         String?           // N/NE/E/SE/S/SW/W/NW

  // Pricing premium components (structured inputs to the rule engine)
  floorPremium        Float?            // AED added per unit because of floor
  viewPremium         Float?            // AED added per unit because of view
  cornerPremium       Float?            // AED added if a corner unit
  orientationPremium  Float?            // AED added per orientation

  // Additional area dimensions
  terraceArea         Float?            // sq metres
  gardenArea          Float?            // sq metres
  plotArea            Float?            // sq metres (relevant for villas/townhouses)

  // Master template + staged release
  unitTypePlanId      String?
  unitTypePlan        UnitTypePlan?     @relation(fields: [unitTypePlanId], references: [id])
  phaseId             String?
  phase               Phase?            @relation(fields: [phaseId], references: [id])

  // Relations
  interests    LeadUnitInterest[]
  deals        Deal[]
  reservations Reservation[]
  offers       Offer[]
  priceHistory UnitPriceHistory[]
  activities   Activity[]         @relation("UnitActivities")
  images       UnitImage[]

  // New post-handover relations
  snagLists            SnagList[]
  handoverChecklists   HandoverChecklist[]
  defectLiabilityPeriod DefectLiabilityPeriod?
  titleDeedTransfers   TitleDeedTransfer[]

  // Lifecycle (schema-only placeholders for future)
  leases        Lease[]
  resaleListings ResaleListing[]
  serviceChargeAllocations ServiceChargeAllocation[]
  facilityWorkOrders FacilityWorkOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, unitNumber])
  @@index([projectId])
  @@index([floor])
  @@index([status])
  @@index([type])
  @@index([unitNumber])
  @@index([projectId, status])
  @@index([projectId, type])
  @@index([projectId, price])
  @@index([phaseId])
  @@index([unitTypePlanId])
}

model UnitStatusHistory {
  id     String @id @default(cuid())
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  oldStatus UnitStatus
  newStatus UnitStatus

  changedBy String
  reason    String?

  changedAt DateTime @default(now())

  @@index([unitId])
  @@index([changedAt])
}

model UnitImage {
  id        String        @id @default(cuid())
  unitId    String
  unit      Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)

  url       String        @db.Text
  caption   String?
  type      UnitImageType @default(PHOTO)
  sortOrder Int           @default(0)

  createdAt DateTime      @default(now())

  @@index([unitId])
  @@index([type])
}

// ============================================================
// SECTION 5: LEADS
// ============================================================

model Lead {
  id          String  @id @default(cuid())
  firstName   String
  lastName    String
  phone       String  @unique
  email       String?
  nationality String?

  source          String
  brokerCompanyId String?
  brokerCompany   BrokerCompany? @relation(fields: [brokerCompanyId], references: [id])
  brokerAgentId   String?
  brokerAgent     BrokerAgent?   @relation(fields: [brokerAgentId], references: [id])

  budget Float?
  stage  LeadStage @default(NEW)

  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id])

  assignedAgentId String
  assignedAgent   User   @relation("AssignedLeads", fields: [assignedAgentId], references: [id])

  interests    LeadUnitInterest[]
  activities   Activity[]
  tasks        Task[]
  stageHistory LeadStageHistory[]
  deals        Deal[]
  reservations Reservation[]
  offers       Offer[]
  documents    Document[]

  // Phase 1: structured KYC + joint-owner participation
  kycRecords   KYCRecord[]
  dealParties  DealParty[]

  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([assignedAgentId])
  @@index([stage])
  @@index([projectId])
  @@index([firstName])
  @@index([lastName])
}

model LeadUnitInterest {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  isPrimary Boolean  @default(false)
  addedAt   DateTime @default(now())

  @@unique([leadId, unitId])
  @@index([leadId])
  @@index([unitId])
}

model LeadStageHistory {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  oldStage  LeadStage
  newStage  LeadStage
  changedBy String
  reason    String?

  changedAt DateTime @default(now())

  @@index([leadId])
}

// ============================================================
// SECTION 6: ACTIVITY, TASK, NOTIFICATION
// ============================================================

model Activity {
  id        String   @id @default(cuid())
  // At least one of leadId / dealId / unitId / contactId must be non-null (enforced in application layer)
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dealId    String?
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  unitId    String?
  unit      Unit?    @relation("UnitActivities", fields: [unitId], references: [id], onDelete: SetNull)
  contactId String?
  contact   Contact? @relation("ContactActivities", fields: [contactId], references: [id], onDelete: SetNull)

  type    String  // CALL, EMAIL, WHATSAPP, MEETING, NOTE, STAGE_CHANGE, SITE_VISIT, etc.
  summary String  @db.Text
  outcome String? @db.Text

  callDuration Int?    // minutes
  messageId    String? // WhatsApp message ID

  // For SITE_VISIT activities: which unit was physically visited
  siteVisitUnitId String?

  activityDate DateTime @default(now()) // when the activity happened
  followUpDate DateTime?
  createdBy    String   // User email or id
  createdAt    DateTime @default(now())

  @@index([leadId])
  @@index([dealId])
  @@index([unitId])
  @@index([contactId])
  @@index([createdAt])
  @@index([activityDate])
  @@index([leadId, activityDate])
}

model Task {
  id    String @id @default(cuid())

  title    String
  type     TaskType     @default(FOLLOW_UP)
  priority TaskPriority @default(MEDIUM)
  status   TaskStatus   @default(PENDING)

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dealId String?
  deal   Deal?   @relation("DealTasks", fields: [dealId], references: [id], onDelete: SetNull)

  assignedToId String?
  assignedTo   User?   @relation("AssignedTasks", fields: [assignedToId], references: [id], onDelete: SetNull)

  dueDate     DateTime
  notes       String?  @db.Text
  completedAt DateTime?

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([dealId])
  @@index([assignedToId])
  @@index([dueDate])
  @@index([status])
}

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  message  String
  leadId   String?
  read     Boolean @default(false)

  type     NotificationType     @default(GENERAL)
  entityId   String? // relevant entity id (dealId, unitId, paymentId …)
  entityType String? // "DEAL", "UNIT", "PAYMENT", etc.
  priority NotificationPriority @default(NORMAL)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([type])
  @@index([priority])
}

// ============================================================
// SECTION 7: BROKER
// ============================================================

model BrokerCompany {
  id    String  @id @default(cuid())
  name  String
  email String?
  phone String?

  status BrokerCompanyStatus @default(PENDING_APPROVAL)

  agents BrokerAgent[]
  leads  Lead[]
  deals  Deal[]
  commissions Commission[]

  reraLicenseNumber  String?
  reraLicenseExpiry  DateTime?
  tradeLicenseNumber String?
  tradeLicenseCopyUrl   String?
  vatCertificateNo      String?
  vatCertificateUrl     String?
  corporateTaxCertUrl   String?
  officeRegistrationNo  String?
  ornCertificateUrl     String?
  officeManagerBrokerId String?
  website               String?
  officeNo              String?
  buildingName          String?
  neighborhood          String?
  emirate               String?
  postalCode            String?
  bankName              String?
  bankAccountName       String?
  bankAccountNo         String?
  bankIban              String?
  bankCurrency          String?  @default("AED")
  bankSwiftCode         String?
  commissionRate     Float    @default(4)

  // RERA expiry alert tracking — set when monitor job emits an alert so it doesn't double-fire
  licenseExpiryAlertedAt DateTime?

  createdAt DateTime @default(now())

  @@index([name])
  @@index([reraLicenseExpiry])
  @@index([status])
}

enum BrokerCompanyStatus {
  ACTIVE
  INACTIVE
  PENDING_APPROVAL
}

model BrokerAgent {
  id        String        @id @default(cuid())
  companyId String
  company   BrokerCompany @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name      String
  firstName String?
  lastName  String?
  email     String?
  phone     String?

  reraCardNumber  String?
  reraCardExpiry  DateTime?
  eidNo           String?
  eidExpiry       DateTime?
  eidFrontUrl     String?
  eidBackUrl      String?
  acceptedConsent Boolean   @default(false)

  leads Lead[]
  deals Deal[]

  // RERA card expiry alert tracking
  licenseExpiryAlertedAt DateTime?

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([reraCardExpiry])
}

// ============================================================
// SECTION 8: RESERVATION & OFFER
// ============================================================

model Reservation {
  id     String @id @default(cuid())
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  status    ReservationStatus @default(ACTIVE)
  expiresAt DateTime

  reservedBy String  // userId who created this reservation
  notes      String? @db.Text

  convertedToDealId String? // set when status = CONVERTED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([unitId])
  @@index([leadId])
  @@index([status])
  @@index([expiresAt])
}

model Offer {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  paymentPlanId String?
  paymentPlan   PaymentPlan? @relation(fields: [paymentPlanId], references: [id])

  offeredPrice   Float
  originalPrice  Float  // unit.price at time of offer
  discountAmount Float  @default(0)
  discountPct    Float  @default(0)

  notes     String? @db.Text
  status    OfferStatus @default(ACTIVE)
  expiresAt DateTime?

  rejectedReason String?
  acceptedBy     String? // userId

  createdBy String  // userId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([unitId])
  @@index([status])
  @@index([paymentPlanId])
}

// ============================================================
// SECTION 9: PAYMENT PLAN (template)
// ============================================================

model PaymentPlan {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  templateVersion Int @default(1) // bumped when milestones change after deals reference this plan

  milestones PaymentPlanMilestone[]
  deals      Deal[]
  offers     Offer[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model PaymentPlanMilestone {
  id     String      @id @default(cuid())
  planId String
  plan   PaymentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  label           String
  percentage      Float
  triggerType     MilestoneTrigger @default(DAYS_FROM_RESERVATION)

  isDLDFee   Boolean @default(false)
  isAdminFee Boolean @default(false)

  daysFromReservation     Int?       // used when triggerType = DAYS_FROM_RESERVATION
  fixedDate               DateTime?  // used when triggerType = FIXED_DATE
  triggerConstructionPct  Float?     // used when triggerType = ON_CONSTRUCTION_PCT (0..100)
  sortOrder               Int

  createdAt DateTime @default(now())

  @@index([planId])
}

// ============================================================
// SECTION 10: DEAL
// ============================================================

model Deal {
  id         String @id @default(cuid())
  dealNumber String @unique

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id])

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id])

  // Traceability to the reservation / offer that originated this deal
  reservationId String?
  offerId       String?

  isActive Boolean   @default(true) // only ONE active deal per unit at a time (enforced in app layer)
  stage    DealStage @default(RESERVATION_PENDING)

  stageHistory DealStageHistory[]

  salePrice         Float
  discount          Float  @default(0)
  discountReason    String?
  reservationAmount Float  @default(0)

  dldFee  Float
  adminFee Float @default(5000)

  paymentPlanId String
  paymentPlan   PaymentPlan @relation(fields: [paymentPlanId], references: [id])

  payments Payment[]

  reservationDate     DateTime
  oqoodDeadline       DateTime
  spaSignedDate       DateTime?
  oqoodRegisteredDate DateTime?

  documents  Document[]
  commission Commission?
  activities Activity[]
  tasks      Task[]     @relation("DealTasks")

  brokerCompanyId String?
  brokerCompany   BrokerCompany? @relation(fields: [brokerCompanyId], references: [id])
  brokerAgentId   String?
  brokerAgent     BrokerAgent?   @relation(fields: [brokerAgentId], references: [id])

  // Per-deal financial overrides (null = use project defaults)
  commissionRateOverride Float?   // overrides brokerCompany.commissionRate when set
  adminFeeWaived         Boolean  @default(false)
  adminFeeWaivedReason   String?
  adminFeeWaivedBy       String?
  dldPaidBy              String   @default("BUYER") // "BUYER" | "DEVELOPER"
  dldWaivedReason        String?
  dldWaivedBy            String?

  notes     String?  @db.Text

  // Reminder controls (finance collections)
  remindersPaused       Boolean   @default(false)
  remindersPausedReason String?   @db.Text
  remindersPausedUntil  DateTime?

  // ----- Phase 1 expansions -----
  // Multi-currency snapshot (manual FX entry by finance)
  currency       String?   @default("AED")
  fxRate         Float?    // 1 unit of `currency` = fxRate * AED at signing
  fxSnapshotAt   DateTime?

  // Structured DLD / Oqood references (replaces ad-hoc note fields)
  dldRegistrationNumber String?
  oqoodNumber           String?
  formIIssuedDate       DateTime?

  // Joint owners
  parties        DealParty[]

  // Post-handover relations
  handoverChecklists HandoverChecklist[]
  refundRequests     RefundRequest[]
  invoices           Invoice[]
  receipts           Receipt[]
  titleDeedTransfers TitleDeedTransfer[]
  commissionSplits   CommissionSplit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([unitId])
  @@index([stage])
  @@index([isActive])
  @@index([reservationDate])
  @@index([dealNumber])
}

model DealStageHistory {
  id     String @id @default(cuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  oldStage  DealStage
  newStage  DealStage
  changedBy String
  reason    String?

  changedAt DateTime @default(now())

  @@index([dealId])
}

// ============================================================
// SECTION 11: PAYMENT
// ============================================================

model Payment {
  id     String @id @default(cuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  milestoneLabel String
  amount         Float  // current effective amount (may reflect adjustments)
  originalAmount Float  // amount when first created — immutable audit trail
  adjustedAmount Float? // non-null if a manual adjustment has been made
  adjustmentReason String?
  percentage     Float

  dueDate DateTime
  status  PaymentStatus @default(PENDING)

  paidDate      DateTime?
  paidBy        String?
  paymentMethod String?
  receiptKey    String?
  notes         String? @db.Text

  pdcNumber      String?
  pdcBank        String?
  pdcDate        DateTime? // date written on the cheque
  pdcClearedDate DateTime?
  pdcBouncedDate DateTime?

  // Living schedule support
  sortOrder       Int              @default(0)
  milestoneType   String           @default("PLAN") // "PLAN" | "CUSTOM" | "DEVELOPER_COST"
  scheduleTrigger MilestoneTrigger @default(DAYS_FROM_RESERVATION)
  isWaived      Boolean @default(false)
  waivedBy      String?
  waivedAt      DateTime?
  waivedReason  String?

  partialPayments PartialPayment[]
  auditLog        PaymentAuditLog[]
  reminderLogs    ReminderLog[]

  // Reminder tracking
  lastReminderSentAt DateTime?
  reminderCount      Int       @default(0)

  // ----- Phase 1 expansions -----
  // Multi-currency snapshot at the moment money was received
  currency       String?   @default("AED")
  fxRate         Float?    // 1 unit of `currency` = fxRate AED
  fxSnapshotAt   DateTime?

  // Construction-progress trigger linkage
  triggerConstructionPct  Float?           // mirror of plan milestone if scheduleTrigger=ON_CONSTRUCTION_PCT
  constructionMilestoneId String?
  constructionMilestone   ConstructionMilestone? @relation(fields: [constructionMilestoneId], references: [id])

  // Late-fee accumulation
  lateFeeApplied         Float    @default(0)
  lateFeeLastAppliedAt   DateTime?

  // Document linkage
  invoices Invoice[]
  receipts Receipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([status])
  @@index([dueDate])
  @@index([dealId, status])
  @@index([constructionMilestoneId])
}

model PartialPayment {
  id        String  @id @default(cuid())
  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  amount        Float
  paidDate      DateTime
  paymentMethod String
  paidBy        String
  receiptKey    String?
  notes         String? @db.Text

  createdAt DateTime @default(now())

  @@index([paymentId])
}

model PaymentAuditLog {
  id        String  @id @default(cuid())
  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  action    String
  reason    String?
  changedBy String

  changedAt DateTime @default(now())

  @@index([paymentId])
}

enum ReminderRuleType {
  BEFORE_DUE   // 7 days before due
  ON_DUE       // on the due date
  OVERDUE_7    // 7 days after due
  OVERDUE_30   // 30 days after due
}

model ReminderLog {
  id        String            @id @default(cuid())
  paymentId String
  payment   Payment           @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  ruleType  ReminderRuleType
  sentAt    DateTime          @default(now())
  email     String?           // email it was sent to (null = no email, notification only)
  status    String            @default("SENT") // SENT | FAILED | SKIPPED_NO_EMAIL | SKIPPED_PAUSED

  @@index([paymentId])
  @@index([paymentId, ruleType])
}

// ============================================================
// SECTION 12: COMMISSION & DOCUMENT
// ============================================================

model Commission {
  id     String @id @default(cuid())
  dealId String @unique
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  brokerCompanyId String?
  brokerCompany   BrokerCompany? @relation(fields: [brokerCompanyId], references: [id])

  amount Float
  rate   Float

  status CommissionStatus @default(NOT_DUE)

  spaSignedMet Boolean @default(false)
  oqoodMet     Boolean @default(false)

  approvedDate DateTime?
  approvedBy   String?

  paidDate   DateTime?
  paidAmount Float?
  paidVia    String?
  receiptKey String?

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([status])
  @@index([brokerCompanyId])
}

model Document {
  id     String  @id @default(cuid())
  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  type     DocumentType
  source   DocumentSource @default(UPLOADED)
  name     String
  key      String         @default("")
  mimeType String         @default("")
  version  Int            @default(1)

  dataSnapshot Json?

  contractStatus ContractStatus @default(DRAFT)

  expiryDate DateTime?
  uploadedBy String
  uploadedAt DateTime @default(now())

  softDeleted Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([dealId])
  @@index([leadId])
  @@index([type])
  @@index([source])
}

// ============================================================
// SECTION 12b: STAGE DOCUMENT RULES
// ============================================================

// Defines which documents are required before a deal can enter a given stage.
// projectId=null means the rule applies globally (all projects).
// Per-project rules override global rules for the same stage+documentType.
model StageDocumentRule {
  id           String       @id @default(cuid())
  projectId    String?
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  dealStage    DealStage    // destination stage that requires this document
  documentType DocumentType // required document type
  required     Boolean      @default(true)
  label        String       // e.g. "Signed SPA Agreement"

  createdAt DateTime @default(now())

  @@unique([projectId, dealStage, documentType])
  @@index([dealStage])
  @@index([projectId])
}

// ============================================================
// SECTION 13: LATE FEE RULES
// ============================================================

model LateFeeRule {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name             String
  triggerAfterDays Int
  feeType          LateFeeType
  feeAmount        Float
  maxFeeAmount     Float?
  isActive         Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([projectId])
}

// ============================================================
// SECTION 14: PRICING ENGINE
// ============================================================

model PricingRule {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name  String
  scope PricingScope

  // JSON conditions: { "floor_gte": 10, "view": "SEA", "type": "TWO_BR" }
  conditions Json

  adjustmentType  PricingAdjustmentType
  adjustmentValue Float

  priority  Int     @default(0)
  isActive  Boolean @default(true)

  validFrom  DateTime?
  validUntil DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([scope])
  @@index([isActive])
}

model UnitPriceHistory {
  id     String @id @default(cuid())
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  oldPrice  Float
  newPrice  Float
  changedBy String
  reason    String?
  ruleId    String? // PricingRule that triggered this change, if any

  changedAt DateTime @default(now())

  @@index([unitId])
  @@index([changedAt])
}

// ============================================================
// SECTION 15: EVENT SOURCING & BACKGROUND JOBS
// ============================================================

model DomainEvent {
  id            String    @id @default(cuid())
  eventType     String    // e.g. "DEAL_CREATED", "UNIT_RESERVED"
  aggregateId   String    // entity id (dealId, unitId, leadId …)
  aggregateType String    // "DEAL", "UNIT", "LEAD", etc.
  payload       Json
  version       Int       @default(1)
  processedAt   DateTime?
  createdAt     DateTime  @default(now())

  @@index([aggregateId])
  @@index([eventType])
  @@index([createdAt])
  @@index([processedAt])
}

model BackgroundJob {
  id          String    @id @default(cuid())
  type        String    // "RESERVATION_EXPIRY", "PAYMENT_REMINDER", "OQOOD_ALERT"
  payload     Json
  status      JobStatus @default(PENDING)
  scheduledAt DateTime
  startedAt   DateTime?
  completedAt DateTime?
  failedAt    DateTime?
  error       String?   @db.Text
  retryCount  Int       @default(0)
  maxRetries  Int       @default(3)

  createdAt DateTime @default(now())

  @@index([status])
  @@index([scheduledAt])
  @@index([type])
}

// ============================================================
// SECTION 16: APP SETTINGS
// ============================================================

model AppSettings {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Branding
  companyName  String?
  logoUrl      String?
  primaryColor String?

  // Localization
  timezone   String @default("Asia/Dubai")
  currency   String @default("AED")
  dateFormat String @default("DD/MM/YYYY")

  // Communication (foundation for email / WhatsApp / SMS integration)
  defaultFromEmail String?
  defaultFromName  String?
  whatsappNumber   String?
  smsProvider      String? // e.g. "twilio"
  emailProvider    String? // e.g. "sendgrid", "smtp"

  // SMTP delivery settings (used when emailProvider = "smtp")
  smtpHost     String?
  smtpPort     Int?
  smtpUsername String?
  smtpPassword String?

  // Finance — payment instructions injected into invoices and reminder emails
  paymentInstructions String? @db.Text

  // Email templates (JSON object keyed by template name)
  emailTemplates Json?

  // Notification preferences stored as JSON blob
  notificationPrefs Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// SECTION 17: CONTACTS
// ============================================================

model Contact {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  firstName   String
  lastName    String?
  email       String?
  phone       String?
  whatsapp    String?
  company     String?
  jobTitle    String?
  nationality String?
  source      ContactSource @default(MANUAL)
  notes       String?       @db.Text
  tags        String?       // comma-separated

  activities Activity[] @relation("ContactActivities")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([email])
  @@index([phone])
  @@index([firstName])
}

// ============================================================
// SECTION 18: PHASE & UNIT TYPE PLAN (Phase 1 — master data)
// ============================================================

// A Phase models a staged release inside a single tower (e.g. lower floors first,
// then upper floors, then penthouses).  Multi-tower hierarchy is intentionally
// not modelled — each Project is one tower.
model Phase {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name        String     // e.g. "Phase 1 — Floors 1-15"
  code        String?    // short code, e.g. "P1"
  description String?    @db.Text
  sortOrder   Int        @default(0)

  // Floor band this phase covers (inclusive). Null = phase scope decided by unit assignment only.
  floorFrom   Int?
  floorTo     Int?

  releaseStage     ReleaseStage @default(INTERNAL)
  releaseStageAt   DateTime?    // when the current releaseStage was entered
  publicLaunchDate DateTime?    // optional planned date for PUBLIC release

  units                Unit[]
  releaseHistory       PhaseReleaseHistory[]
  constructionMilestones ConstructionMilestone[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, name])
  @@index([projectId])
  @@index([releaseStage])
}

model PhaseReleaseHistory {
  id      String  @id @default(cuid())
  phaseId String
  phase   Phase   @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  oldStage  ReleaseStage
  newStage  ReleaseStage
  changedBy String
  reason    String?

  changedAt DateTime @default(now())

  @@index([phaseId])
  @@index([changedAt])
}

// Master template for unit instances of the same layout (e.g. "1BR-A", "2BR-Premium").
// A Unit references its UnitTypePlan; default values are inherited at creation time.
model UnitTypePlan {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  code        String         // unique within project, e.g. "1BR-A"
  name        String         // human-readable name
  type        UnitType
  description String?        @db.Text

  // Default geometry
  area              Float?    // total sq metres
  internalArea      Float?
  externalArea      Float?
  bathrooms         Int?
  parkingSpaces     Int?
  terraceArea       Float?
  gardenArea        Float?

  // Default pricing inputs
  basePrice         Float?

  // Marketing
  floorPlanUrl      String?   @db.Text
  brochureUrl       String?   @db.Text

  units Unit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, code])
  @@index([projectId])
  @@index([type])
}

// ============================================================
// SECTION 19: KYC (Phase 1 — structured customer due diligence)
// ============================================================

// One KYCRecord per Lead per identity-document set. We support multiple records
// per Lead so the data scales for joint-owner deals (each party can have its own KYC).
model KYCRecord {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  status     KYCStatus  @default(PENDING)
  riskRating RiskRating @default(LOW)

  // Identity document fields
  idType         String?    // PASSPORT | EMIRATES_ID | OTHER
  idNumber       String?
  idIssueDate    DateTime?
  idExpiryDate   DateTime?
  idIssuingCountry String?

  // Demographics
  nationality       String?
  residencyStatus   String?    // RESIDENT | NON_RESIDENT | CITIZEN
  visaNumber        String?
  visaExpiryDate    DateTime?
  occupation        String?
  employer          String?
  pepFlag           Boolean    @default(false)
  pepNotes          String?    @db.Text

  // Source-of-funds declaration (no live AML provider — text declaration only)
  sourceOfFunds        String?  @db.Text
  sourceOfFundsDocKey  String?  // S3 key if a supporting document was uploaded

  // Address
  addressLine1   String?
  addressLine2   String?
  city           String?
  country        String?
  postalCode     String?

  // Periodic refresh tracking
  reviewedAt   DateTime?
  reviewedBy   String?
  expiresAt    DateTime?       // soonest of idExpiryDate / visaExpiryDate / annual review
  expiryAlertedAt DateTime?

  notes      String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([status])
  @@index([riskRating])
  @@index([expiresAt])
}

// ============================================================
// SECTION 20: DEAL PARTIES (Phase 1 — joint owners)
// ============================================================

// A DealParty links a Lead to a Deal with an ownership percentage and role.
// Application-layer invariant: per Deal, sum of ownershipPercentage = 100,
// and exactly one party has role = PRIMARY.
model DealParty {
  id     String @id @default(cuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id])

  role                 PartyRole @default(PRIMARY)
  ownershipPercentage  Float     // 0..100

  // Per-party signature snapshot when SPA is generated
  signedAt    DateTime?
  signedName  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dealId, leadId])
  @@index([dealId])
  @@index([leadId])
}

// ============================================================
// SECTION 21: INVOICE & RECEIPT (Phase 1 — financial primitives)
// ============================================================

// Sequential numbering source. One row per (organizationId, sequenceKey, fiscalYear).
// Use a transactional UPDATE to obtain the next value to guarantee gap-free numbers.
model OrgNumberSequence {
  id             String @id @default(cuid())
  organizationId String
  sequenceKey    String   // e.g. "INVOICE", "RECEIPT", "REFUND"
  fiscalYear     Int      // e.g. 2026
  prefix         String   @default("")
  nextValue      Int      @default(1)
  width          Int      @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, sequenceKey, fiscalYear])
  @@index([organizationId])
}

model Invoice {
  id     String @id @default(cuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id])

  invoiceNumber String   @unique // generated via OrgNumberSequence
  fiscalYear    Int

  status     InvoiceStatus @default(DRAFT)
  issuedAt   DateTime?
  dueDate    DateTime?

  currency   String  @default("AED")
  fxRate     Float?
  fxSnapshotAt DateTime?

  subtotal   Float
  vatTotal   Float   @default(0)
  total      Float

  // Snapshot of payee identity at issue time
  buyerName       String?
  buyerAddress    String?  @db.Text
  trnNumber       String?  // tax registration number printed

  pdfKey     String?  // S3 key of generated PDF (Handlebars + Puppeteer)
  notes      String?  @db.Text

  lines      InvoiceLine[]
  receipts   Receipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([paymentId])
  @@index([status])
  @@index([fiscalYear])
}

model InvoiceLine {
  id        String @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  kind        InvoiceLineKind @default(OTHER)
  description String
  quantity    Float           @default(1)
  unitPrice   Float
  vatPercent  Float           @default(0)
  vatAmount   Float           @default(0)
  amount      Float           // (unitPrice * quantity) net of VAT

  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  @@index([invoiceId])
}

model Receipt {
  id     String @id @default(cuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id])
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  receiptNumber String   @unique
  fiscalYear    Int

  amount        Float
  currency      String   @default("AED")
  fxRate        Float?
  fxSnapshotAt  DateTime?

  paymentMethod String?
  paidDate      DateTime
  paidBy        String?  // userId who recorded
  payerName     String?

  pdfKey        String?
  notes         String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([paymentId])
  @@index([invoiceId])
  @@index([fiscalYear])
}

// ============================================================
// SECTION 22: REFUND (Phase 1 — financial primitives)
// ============================================================

model RefundRequest {
  id     String @id @default(cuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  amount     Float
  currency   String       @default("AED")
  reason     String       @db.Text
  status     RefundStatus @default(REQUESTED)

  requestedBy String
  requestedAt DateTime  @default(now())

  approvedBy String?
  approvedAt DateTime?
  rejectedReason String? @db.Text

  processedBy String?
  processedAt DateTime?
  processedReference String? // bank ref / cheque number entered manually

  notes      String?  @db.Text

  approvals  RefundApproval[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([status])
}

model RefundApproval {
  id        String @id @default(cuid())
  refundId  String
  refund    RefundRequest @relation(fields: [refundId], references: [id], onDelete: Cascade)

  decision   String      // APPROVED | REJECTED
  decidedBy  String
  decidedAt  DateTime    @default(now())
  comment    String?     @db.Text

  @@index([refundId])
}

// ============================================================
// SECTION 23: ESCROW (Phase 1 — RERA record-keeping)
// ============================================================

model EscrowAccount {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  bankName    String
  branch      String?
  accountName String
  accountNo   String
  iban        String?
  swift       String?
  currency    String   @default("AED")

  trusteeAccountId String?
  trusteeAccount   TrusteeAccount? @relation(fields: [trusteeAccountId], references: [id])

  isActive  Boolean  @default(true)
  openedAt  DateTime @default(now())
  closedAt  DateTime?

  ledger    EscrowLedgerEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([trusteeAccountId])
}

model TrusteeAccount {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  trusteeName       String
  registrationNo    String?
  contactEmail      String?
  contactPhone      String?
  notes             String? @db.Text

  escrowAccounts EscrowAccount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model EscrowLedgerEntry {
  id        String        @id @default(cuid())
  accountId String
  account   EscrowAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  direction EscrowEntryDirection
  reason    EscrowEntryReason
  amount    Float
  currency  String  @default("AED")

  // Optional links (we don't add reverse relations to Payment/RefundRequest to keep
  // the existing models clean — this is a one-way reference for traceability).
  paymentId      String?
  refundRequestId String?
  externalRef    String?  // bank statement reference or developer drawdown ref

  postedAt   DateTime @default(now())
  postedBy   String
  notes      String?  @db.Text

  @@index([accountId])
  @@index([postedAt])
  @@index([paymentId])
  @@index([refundRequestId])
}

// ============================================================
// SECTION 24: CONSTRUCTION MILESTONES (Phase 1)
// ============================================================

// Construction progress is tracked at the Phase level (or Project level if a phase
// is not assigned). Ops update percentComplete manually; when the percentage crosses
// the threshold of a PaymentPlanMilestone with triggerType=ON_CONSTRUCTION_PCT,
// the matching Payment.dueDate is set.
model ConstructionMilestone {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  phaseId   String?
  phase     Phase?  @relation(fields: [phaseId], references: [id])

  stage             ConstructionStage
  label             String
  description       String?  @db.Text
  percentComplete   Float    @default(0)
  certificateKey    String?  // S3 key of consultant's certificate
  consultantName    String?
  expectedDate      DateTime?
  achievedDate      DateTime?

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([phaseId])
  @@index([stage])
}

// ============================================================
// SECTION 25: HANDOVER CHECKLIST (Phase 1)
// ============================================================

model HandoverChecklist {
  id     String @id @default(cuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  completedBy String?

  customerSignedOffAt DateTime?
  customerSignedName  String?
  customerSignatureKey String?  // S3 key for signature image / signed sheet

  notes String? @db.Text

  items HandoverChecklistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([unitId])
}

model HandoverChecklistItem {
  id          String @id @default(cuid())
  checklistId String
  checklist   HandoverChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  // Stable code so seed templates can be re-used (e.g. KEY_HANDOVER, NOC_SERVICE_CHARGE)
  code     String
  label    String
  required Boolean @default(true)

  status     HandoverItemStatus @default(PENDING)
  completedAt DateTime?
  completedBy String?
  evidenceKey String?            // S3 key of supporting document
  notes       String?            @db.Text
  sortOrder   Int                @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([checklistId, code])
  @@index([checklistId])
  @@index([status])
}

// ============================================================
// SECTION 26: SNAGGING & DLP (Phase 1)
// ============================================================

model SnagList {
  id     String @id @default(cuid())
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  // A unit may have multiple snag lists over time (pre-handover walk-through, post-handover, end-of-DLP).
  label       String   @default("Snag List")
  raisedAt    DateTime @default(now())
  closedAt    DateTime?

  items SnagItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([unitId])
}

model SnagItem {
  id     String @id @default(cuid())
  listId String
  list   SnagList @relation(fields: [listId], references: [id], onDelete: Cascade)

  room        String?     // e.g. "Master Bedroom", "Kitchen"
  category    String?     // e.g. "Paint", "Plumbing", "Electrical"
  description String      @db.Text
  severity    SnagSeverity @default(MINOR)
  status      SnagStatus  @default(RAISED)

  contractorName  String?
  contractorEmail String?

  dueDate    DateTime?
  fixedDate  DateTime?
  closedDate DateTime?

  raisedBy   String      // userId
  fixedBy    String?

  rejectionReason String? @db.Text

  photos SnagPhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listId])
  @@index([status])
  @@index([severity])
}

model SnagPhoto {
  id     String @id @default(cuid())
  itemId String
  item   SnagItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  s3Key   String   @db.Text
  caption String?
  takenAt DateTime @default(now())

  // BEFORE = before fix, AFTER = after fix
  kind    String   @default("BEFORE")

  createdAt DateTime @default(now())

  @@index([itemId])
}

model DefectLiabilityPeriod {
  id     String @id @default(cuid())
  unitId String @unique
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  startDate   DateTime
  endDate     DateTime
  months      Int
  notes       String?  @db.Text
  closed      Boolean  @default(false)
  closedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([endDate])
}

// ============================================================
// SECTION 27: TITLE DEED (Phase 1)
// ============================================================

model TitleDeedTransfer {
  id     String @id @default(cuid())
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  dealId String?
  deal   Deal?  @relation(fields: [dealId], references: [id])

  status        TitleDeedStatus @default(PENDING)
  deedNumber    String?
  registryRef   String?
  issuedDate    DateTime?
  transferredAt DateTime?

  buyerName     String?
  sellerName    String?
  notes         String?  @db.Text

  documentKey   String?  // S3 key of scanned title deed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([unitId])
  @@index([dealId])
  @@index([status])
}

// ============================================================
// SECTION 28: TIERED COMMISSION (Phase 1)
// ============================================================

model TieredCommissionRule {
  id        String  @id @default(cuid())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  priority    Int      @default(0)

  validFrom   DateTime?
  validUntil  DateTime?

  tiers CommissionTier[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([isActive])
}

model CommissionTier {
  id     String @id @default(cuid())
  ruleId String
  rule   TieredCommissionRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  // Tier band by deal sale price
  minSalePrice Float?
  maxSalePrice Float?
  // Or by units-sold-by-broker count
  minUnitsSold Int?
  maxUnitsSold Int?

  ratePercent Float
  flatBonus   Float @default(0)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())

  @@index([ruleId])
}

// Per-deal commission split between company / agent / sub-agent / referrer.
model CommissionSplit {
  id     String @id @default(cuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  party       CommissionSplitParty
  partyName   String?    // free-form (sub-agent name, referrer name)
  partyId     String?    // optional FK-as-string (BrokerAgent.id, etc.)
  percentage  Float      // % of total commission
  amount      Float?     // computed when commission is approved
  status      String     @default("PENDING") // PENDING | APPROVED | PAID
  paidAt      DateTime?
  paidVia     String?
  notes       String?    @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([party])
}

// ============================================================
// SECTION 29: LIFECYCLE PLACEHOLDERS (schema only — no services / UI yet)
// ============================================================

model Lease {
  id     String @id @default(cuid())
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  status         LeaseStatus @default(DRAFT)
  startDate      DateTime
  endDate        DateTime
  annualRent     Float
  currency       String      @default("AED")
  securityDeposit Float      @default(0)
  ejariNumber    String?     // populated when registered with Ejari
  notes          String?     @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([unitId])
  @@index([tenantId])
  @@index([status])
}

model Tenant {
  id        String  @id @default(cuid())
  firstName String
  lastName  String?
  email     String?
  phone     String?
  emiratesId String?
  passportNo String?
  nationality String?

  leases Lease[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([email])
}

model ServiceCharge {
  id        String @id @default(cuid())
  // tied to a project; per-unit allocations live in ServiceChargeAllocation
  projectId String

  fiscalYear Int
  ratePerSqm Float
  totalBudget Float?
  notes      String? @db.Text

  allocations ServiceChargeAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([fiscalYear])
}

model ServiceChargeAllocation {
  id              String @id @default(cuid())
  serviceChargeId String
  serviceCharge   ServiceCharge @relation(fields: [serviceChargeId], references: [id], onDelete: Cascade)

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  amount      Float
  paid        Boolean @default(false)
  paidAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceChargeId, unitId])
  @@index([unitId])
}

model FacilityWorkOrder {
  id     String @id @default(cuid())
  unitId String?
  unit   Unit?  @relation(fields: [unitId], references: [id])

  category    String
  description String  @db.Text
  status      FacilityWorkOrderStatus @default(OPEN)
  raisedBy    String  // user or tenant id
  assignedTo  String?
  raisedAt    DateTime @default(now())
  resolvedAt  DateTime?
  notes       String?  @db.Text

  @@index([unitId])
  @@index([status])
}

model ResaleListing {
  id     String @id @default(cuid())
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  askingPrice Float
  currency    String  @default("AED")
  status      ResaleStatus @default(ACTIVE)
  listedAt    DateTime @default(now())
  withdrawnAt DateTime?
  soldAt      DateTime?
  notes       String?  @db.Text

  @@index([unitId])
  @@index([status])
}
