{
  "name": "@samha/api",
  "version": "0.1.0",
  "description": "Samha CRM Backend API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:push": "prisma db push",
    "db:seed": "tsx src/db/seed.ts",
    "db:backfill-contacts": "tsx src/db/backfillContacts.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "test:integration": "vitest run src/__tests__/",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "@clerk/express": "^1.0.0",
    "@prisma/client": "^5.8.0",
    "@types/nodemailer": "^8.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.3.0",
    "express": "^4.18.2",
    "libphonenumber-js": "^1.12.43",
    "mailparser": "^3.6.6",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^6.0.2",
    "vite": "8.0.8",
    "winston": "^3.19.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/mailparser": "^3.4.4",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@vitest/ui": "^4.1.4",
    "prisma": "^5.8.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.4"
  },
  "// optionalDependencies": "bullmq + ioredis are ONLY required when JOB_QUEUE_BACKEND=bullmq. Listed as optional so npm install succeeds on platforms / single-instance deployments where Redis isn't available and the homegrown DB-poller (the default) is used. See ADMIN_MANUAL.md §6.6 and apps/api/src/events/jobs/bullmqAdapter.ts.",
  "optionalDependencies": {
    "bullmq": "^5.0.0",
    "ioredis": "^5.4.0"
  }
}
