# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
DATABASE_URL="mysql://user:password@localhost:3306/samha_crm"

# ── Auth ────────────────────────────────────────────────────────────────────
# JWT secret used to sign session cookies. MUST be at least 32 characters.
# Generate with:  openssl rand -hex 64
JWT_SECRET=replace-me-with-a-long-random-secret-min-32-characters
JWT_EXPIRES_IN=12h
COOKIE_NAME=samha_session
# Set to your domain in production (e.g. .samha.ae) — leave blank in dev.
# COOKIE_DOMAIN=

# ── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── Observability (optional) ────────────────────────────────────────────────
# SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# ── Document storage (S3) ───────────────────────────────────────────────────
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=

# ── Seeding ─────────────────────────────────────────────────────────────────
# Default password applied to all seeded users; they are forced to change it on
# first login.
SEED_DEFAULT_PASSWORD=ChangeMe123!
