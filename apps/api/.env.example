DATABASE_URL="mysql://user:password@localhost:3306/samha_crm"
NODE_ENV="development"
PORT=3000

# JWT secrets — generate with: openssl rand -base64 64
JWT_SECRET="replace-with-a-long-random-string"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL_DAYS=30
PASSWORD_RESET_TTL_MIN=60

# CORS allowlist (comma-separated)
ALLOWED_ORIGINS="http://localhost:5173"

# Used in password-reset emails
PASSWORD_RESET_URL_BASE="http://localhost:5173/reset-password"

# Default password seeded into the 5 fixture users (must be changed on first login)
SEED_DEFAULT_PASSWORD="ChangeMe123!"
