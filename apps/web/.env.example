# Frontend env vars. Vite exposes any var prefixed with VITE_ to the browser
# bundle at build time — never put secrets here.

# === REQUIRED ===

# Clerk publishable key. Different per environment (dev / staging / prod).
VITE_CLERK_PUBLISHABLE_KEY="your_clerk_publishable_key"

# Base URL of the API server. Defaults to http://localhost:3000 in dev (Vite
# proxy handles /api). In staging and production this MUST be set to the real
# API host, e.g. https://api.<your-domain>. The bundle is built against this
# value at compile time — you must rebuild after changing it.
VITE_API_URL="http://localhost:3000"

# === OPTIONAL ===

# Sentry project DSN for the web app. When set, ErrorBoundary catches and
# reports unhandled exceptions; navigation errors are captured automatically.
# Leave unset in dev.
# VITE_SENTRY_DSN=""

# Build-time release identifier sent to Sentry for grouping. Typically the git
# tag from CI, e.g. v1.0.0.
# VITE_SENTRY_RELEASE=""
