# ============================================================
# ENVIRONMENT CONFIGURATION TEMPLATES
# Copy and modify for different deployment stages
# ============================================================

# === DEVELOPMENT ===
# Used locally for development

DATABASE_URL="mysql://root:@localhost:3306/samha_crm"
NODE_ENV="development"
PORT=3000

# Auth — generate with: openssl rand -base64 64
JWT_SECRET="replace-with-a-long-random-string"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL_DAYS=30
PASSWORD_RESET_TTL_MIN=60
PASSWORD_RESET_URL_BASE="http://localhost:5173/reset-password"
SEED_DEFAULT_PASSWORD="ChangeMe123!"

# AWS S3 (Development)
AWS_S3_BUCKET="samha-dev-bucket"
AWS_S3_REGION="us-east-1"
AWS_ACCESS_KEY_ID="dev-access-key"
AWS_SECRET_ACCESS_KEY="dev-secret-key"
MAX_UPLOAD_SIZE=52428800

# CORS - Allow localhost ports
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# ============================================================

# === STAGING ===
# Used on staging server before production

# DATABASE_URL="mysql://samha_staging:password@staging-db.internal:3306/samha_crm_staging"
# NODE_ENV="staging"
# PORT=3000
# JWT_SECRET="generated-with-openssl-rand-base64-64"
# PASSWORD_RESET_URL_BASE="https://staging.yourdomain.com/reset-password"

# AWS S3 (Staging)
# AWS_S3_BUCKET="samha-staging-bucket"
# AWS_S3_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="staging-access-key"
# AWS_SECRET_ACCESS_KEY="staging-secret-key"
# MAX_UPLOAD_SIZE=52428800

# CORS - Allow staging domain
# ALLOWED_ORIGINS="https://staging.yourdomain.com"

# Logging
# LOG_LEVEL="info"
# DEBUG="false"

# ============================================================

# === PRODUCTION ===
# Used on production server (cPanel)

# DATABASE_URL="mysql://samha_prod_user:secure_password@localhost:3306/samha_crm_prod"
# NODE_ENV="production"
# PORT=3000
# JWT_SECRET="generated-with-openssl-rand-base64-64"
# PASSWORD_RESET_URL_BASE="https://app.yourdomain.com/reset-password"

# AWS S3 (Production)
# AWS_S3_BUCKET="samha-production-bucket"
# AWS_S3_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="prod-access-key"
# AWS_SECRET_ACCESS_KEY="prod-secret-key"
# MAX_UPLOAD_SIZE=52428800

# CORS - Production domain only
# ALLOWED_ORIGINS="https://app.yourdomain.com"

# Logging & Monitoring
# LOG_LEVEL="warn"
# DEBUG="false"

# Performance
# DB_POOL_MAX=20
# DB_POOL_TIMEOUT_MS=30000
# REQUEST_TIMEOUT_MS=30000

# Rate Limiting
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# ============================================================
# IMPORTANT SECURITY NOTES:
# ============================================================
#
# 1. NEVER commit .env files with real credentials to git
# 2. Use .env.local for sensitive local development
# 3. On cPanel, use SSH to create .env with secure permissions:
#    cat > .env << 'EOF'
#    ... paste secure values ...
#    EOF
#    chmod 600 .env
#
# 4. AWS Credentials:
#    - Use IAM user with minimal required permissions
#    - Rotate keys every 90 days in production
#    - Never use root AWS account credentials
#
# 5. Database Password:
#    - Use strong random password (32+ chars)
#    - Store in cPanel MySQL database user manager
#    - Never expose in logs
#
# 6. Clerk Keys:
#    - Generate per environment (dev, staging, prod)
#    - Keep secret key private
#    - Rotate periodically if compromised
#
# ============================================================
