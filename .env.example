# ============================================================
# ENVIRONMENT CONFIGURATION TEMPLATES
# Copy and modify for different deployment stages.
# Backend canonical reference: apps/api/.env.example
# ============================================================

# === DEVELOPMENT ===
DATABASE_URL="mysql://root:@localhost:3306/samha_crm"
NODE_ENV="development"
PORT=3000

# JWT secret for session cookies — MUST be at least 32 chars.
# Generate: openssl rand -hex 64
JWT_SECRET="replace-me-with-a-long-random-secret-min-32-characters"
JWT_EXPIRES_IN="12h"
COOKIE_NAME="samha_session"
# COOKIE_DOMAIN=".samha.ae"   # set in production

# AWS S3
AWS_S3_BUCKET="samha-dev-bucket"
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="dev-access-key"
AWS_SECRET_ACCESS_KEY="dev-secret-key"
MAX_UPLOAD_SIZE=52428800

# CORS
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Observability
# SENTRY_DSN="https://....ingest.sentry.io/..."
SENTRY_TRACES_SAMPLE_RATE=0

# Seeded users default password (change immediately after seeding)
SEED_DEFAULT_PASSWORD="ChangeMe123!"

# ============================================================
# === STAGING / PRODUCTION ===
# Override the values above; never commit real secrets.
# - DATABASE_URL: dedicated DB user, strong password
# - JWT_SECRET:   unique per environment, rotated on incident
# - COOKIE_DOMAIN: e.g. .samha.ae for cross-subdomain auth
# - ALLOWED_ORIGINS: production frontend host(s) only
# - SENTRY_DSN:    enable in staging + production
# ============================================================

# Security notes:
# 1. Never commit real .env files
# 2. On cPanel, create .env via SSH and chmod 600
# 3. Rotate JWT_SECRET → forces all sessions to log in again
# 4. Use IAM users with minimal S3 permissions; rotate AWS keys quarterly
